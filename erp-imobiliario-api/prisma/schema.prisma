generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model Profile {
  id            String     @id @db.Uuid
  full_name     String?
  email         String?    @unique
  role          String?    @default("corretor")
  avatar_url    String?
  password_hash String?
  birth_date    DateTime?  @db.Date
  cpf           String?    @unique
  created_at    DateTime   @default(now()) @db.Timestamptz(6)

  properties Property[]
  sales      Sale[]
  leads      Lead[]

  @@map("profiles")
  @@schema("public")
}

model Property {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  type          String
  status        String?  @default("Disponível")
  address       String?
  city          String?
  state         String?
  zip_code      String?
  area          Decimal? @db.Decimal
  bedrooms      Int?     @default(0)
  suites        Int?     @default(0)
  bathrooms     Int?     @default(0)
  parking_spots Int?     @default(0)
  price         Decimal  @db.Decimal
  description   String?
  broker_id     String?  @db.Uuid
  broker        Profile? @relation(fields: [broker_id], references: [id])
  images        String[] @default([])
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  sales Sale[]
  leads Lead[]

  @@map("properties")
  @@schema("public")
}

model Client {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  email      String?
  phone      String?
  document   String?
  type       String?
  notes      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  sales Sale[]
  leads Lead[]

  @@map("clients")
  @@schema("public")
}

model Sale {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id           String?   @db.Uuid
  property              Property? @relation(fields: [property_id], references: [id])
  client_id             String?   @db.Uuid
  client                Client?   @relation(fields: [client_id], references: [id])
  broker_id             String?   @db.Uuid
  broker                Profile?  @relation(fields: [broker_id], references: [id])
  total_value           Decimal   @db.Decimal
  commission_value      Decimal?  @db.Decimal
  commission_percentage Decimal?  @db.Decimal
  status                String?   @default("Em Negociação")
  sale_date             DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_at            DateTime  @default(now()) @db.Timestamptz(6)

  @@map("sales")
  @@schema("public")
}

model Lead {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id   String   @db.Uuid
  client      Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  property_id String?  @db.Uuid
  property    Property? @relation(fields: [property_id], references: [id], onDelete: SetNull)
  broker_id   String?  @db.Uuid
  broker      Profile? @relation(fields: [broker_id], references: [id], onDelete: SetNull)
  status      String?  @default("Novo")
  source      String?
  notes       String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@map("leads")
  @@schema("public")
}
